# ============================================================
# 這是「範例檔」。請複製成 backend/.env 再填入真實值。
# backend/.env 已被 .gitignore 排除，不會上傳到 git。
# ============================================================

# backend 監聽的 port。前端預設用 http://localhost:3001 呼叫。
PORT=3001

# ── TWSE 官方 OpenAPI ───────────────────────────────────────
TWSE_API_BASE_URL=https://openapi.twse.com.tw/v1
TWSE_REQUEST_TIMEOUT_MS=30000
TWSE_USER_AGENT=database-final-project/1.0

# ── 歷史日線 fallback ───────────────────────────────────────
# TWSE 歷史端點不可用時，後端會改抓 FinMind 的台股日線資料。
# 不填也可使用公開額度；若你有 token，填上後通常可提高穩定性。
FINMIND_TOKEN=

# ── SQL Server 資料庫連線（ncu_db）─────────────────────────
# ⚠️ 下面是「範例值」，請在 backend/.env 換成你自己的。
# ⚠️ 若是接「別人的資料庫」，整段 DB_* 改成對方提供的連線資訊。
DB_HOST=127.0.0.1
DB_PORT=1433
DB_USER=填入你的SQLServer帳號
DB_PASSWORD=填入你的SQLServer密碼
DB_NAME=ncu_db

# 本機開發通常 encrypt=false、trust=true；連雲端(Azure)才把 encrypt 設 true
DB_ENCRYPT=false
DB_TRUST_CERT=true
DB_REQUEST_TIMEOUT_MS=15000

# 登入 token 簽章金鑰（請換成自己的長隨機字串）
AUTH_SECRET=填入一段長隨機字串

# OpenAI API
OPENAI_API_KEY=填入你的_OpenAI_API_Key
OPENAI_MODEL=gpt-5-mini
